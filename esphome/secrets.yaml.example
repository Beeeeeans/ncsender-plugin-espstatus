# secrets.yaml — copy this file to secrets.yaml (same folder) and fill in your values.
# secrets.yaml is listed in .gitignore and will NOT be committed to git.

# WiFi credentials
wifi_ssid:     "YourNetworkSSID"
wifi_password: "YourNetworkPassword"

# Fallback hotspot (shown if the main WiFi connection fails)
fallback_ap_ssid:     "CNC-Status-Fallback"
fallback_ap_password: "cncstatus"

# OTA (over-the-air update) password — used when pushing firmware updates wirelessly
ota_password: "change_me_to_something_secure"

# ESPHome native API key — only needed if you use Home Assistant.
# The ncSender plugin does NOT need this; the API block is commented out in the YAML.
# If you do want HA integration, uncomment the api: block in cnc-status-light.yaml
# and generate a key with:  esphome generate-api-key
# api_encryption_key: "REPLACE_WITH_OUTPUT_OF_esphome_generate-api-key=="
